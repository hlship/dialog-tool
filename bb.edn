{:paths ["release"]
 :deps  {org.clj-commons/pretty {:mvn/version "3.8.0"}}

 :tasks
 {:requires ([clj-commons.ansi :refer [pout]]
             [clojure.string :as string]
             [babashka.fs :as fs]
             [babashka.process :as p]
             [dgt.release :as r :refer [sh]])
  test      {:doc "Run all Clojure tests"
             :task
             (let [{:keys [exit]} (p/shell {:continue true} "clojure -M:test")]
               (System/exit exit))}
  tailwind  {:doc "Watch for changes and regenerate style.css using tailwindcss"
             :task
             (p/shell "npx tailwindcss -i public/style.css -o generated-resources/public/style.css --watch")}
  package     {:doc  "Build a native installer for the current platform (bb package [tag])"
               :task (let [tag (or (first *command-line-args*)
                                   (sh {:out :string :quiet? true}
                                       "git describe --tags --abbrev=0"))]
                       (r/package tag))}
  package-zip {:doc  "Build the zip archive for Homebrew / macOS distribution (bb package-zip [tag])"
               :task (let [tag (or (first *command-line-args*)
                                   (sh {:out :string :quiet? true}
                                       "git describe --tags --abbrev=0"))]
                       (r/package-zip tag))}
  lint      {:doc "Run clj-kondo to lint all fille"
             :task
             (do
               ;; First pass: analyze dependencies to populate .clj-kondo cache
               (p/shell {:continue true}
                 "clj-kondo --copy-configs --dependencies --lint"
                 (-> (p/shell {:out :string} "clojure -A:dev:test -Spath") :out string/trim))
               ;; Second pass: lint project sources using cached dependency info
               (let [{:keys [exit]} (p/shell {:continue true} "clj-kondo --lint src test dev")]
                 (System/exit exit)))}
  sync      {:doc "Copy latest Dialog libraries into this project"
             :task
             (let [source-path (fs/path "../dialog/")
                   output-path (fs/path "resources/template")]
               (doseq [f ["stdlib.dg" "stddebug.dg" "unit.dg"]]
                 (pout [:cyan f])
                 (fs/copy (fs/path source-path f)
                   (fs/path output-path f)
                   {:replace-existing true})))}
  }}
